<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Resume</title>

<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=JetBrains+Mono&display=swap" rel="stylesheet">

<style>
:root {
  --bg: #0a0a0a;
  --text: #ffffff;
  --accent: #00ff88;
  --muted: #888;
}

* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
body {
  font-family: 'JetBrains Mono', monospace;
  background: var(--bg);
  color: var(--text);
  display: grid;
  grid-template-columns: 300px 1fr;
}

/* Sidebar */
aside {
  position: sticky;
  top:0;
  height:100vh;
  padding:40px;
  border-right:1px solid #222;
}

h1 {
  font-family:'Bebas Neue', sans-serif;
  font-size:48px;
}

nav a {
  display:block;
  margin:15px 0;
  color:var(--muted);
  text-decoration:none;
  position:relative;
}

nav a.active,
nav a:hover { color: var(--accent); }

nav a::after {
  content:'';
  position:absolute;
  left:0;
  bottom:-3px;
  width:0;
  height:2px;
  background:var(--accent);
  transition:0.3s;
}

nav a:hover::after { width:100%; }

/* Main */
main { padding:60px; }
section {
  margin-bottom:80px;
  opacity:0;
  transform: translateY(30px);
  transition: all 0.8s ease;
}
section.visible {
  opacity:1;
  transform: translateY(0);
}

h2 {
  font-family:'Bebas Neue';
  font-size:36px;
  margin-bottom:20px;
}

p, li { color: var(--muted); line-height:1.6; }

/* Skills bars */
.skill {
  margin:15px 0;
}
.bar {
  height:6px;
  background:#222;
  overflow:hidden;
}
.bar-fill {
  height:100%;
  width:0;
  background:var(--accent);
  transition:1s;
}

/* Cursor */
.cursor {
  width:10px;
  height:10px;
  border-radius:50%;
  background:var(--accent);
  position:fixed;
  pointer-events:none;
}

/* Responsive */
@media(max-width:768px){
  body { grid-template-columns:1fr; }
  aside { position:relative; height:auto; border:none; }
}

/* Print */
@media print {
  body { background:white; color:black; }
  aside { display:none; }
}
</style>
</head>

<body>
<div class="cursor"></div>

<aside>
  <h1>[Your Name]</h1>
  <p>[Your Title]</p>
  <nav>
    <a href="#about">About</a>
    <a href="#experience">Experience</a>
    <a href="#skills">Skills</a>
    <a href="#projects">Projects</a>
    <a href="#education">Education</a>
  </nav>
</aside>

<main>

<section id="about">
<h2>About</h2>
<p>[Your summary]</p>
</section>

<section id="experience">
<h2>Experience</h2>
<ul>
<li>[Job details]</li>
<li>[Job details]</li>
</ul>
</section>

<section id="skills">
<h2>Skills</h2>
<div class="skill">
<p>JavaScript</p>
<div class="bar"><div class="bar-fill" data-width="90%"></div></div>
</div>
<div class="skill">
<p>Python</p>
<div class="bar"><div class="bar-fill" data-width="85%"></div></div>
</div>
</section>

<section id="projects">
<h2>Projects</h2>
<ul>
<li>[Project]</li>
<li>[Project]</li>
</ul>
</section>

<section id="education">
<h2>Education</h2>
<p>[Your education]</p>
</section>

</main>

<script>
// Scroll animation
const sections = document.querySelectorAll("section");
window.addEventListener("scroll", () => {
  sections.forEach(sec => {
    const top = sec.getBoundingClientRect().top;
    if(top < window.innerHeight - 100){
      sec.classList.add("visible");
    }
  });
});

// Skill animation
const fills = document.querySelectorAll('.bar-fill');
window.addEventListener('scroll', () => {
  fills.forEach(f => {
    const top = f.getBoundingClientRect().top;
    if(top < window.innerHeight){
      f.style.width = f.dataset.width;
    }
  });
});

// Scroll spy
const links = document.querySelectorAll("nav a");
window.addEventListener("scroll", () => {
  sections.forEach(sec => {
    let id = sec.getAttribute("id");
    if(window.scrollY >= sec.offsetTop - 200){
      links.forEach(a => a.classList.remove("active"));
      document.querySelector(`nav a[href="#${id}"]`).classList.add("active");
    }
  });
});

// Cursor
const cursor = document.querySelector('.cursor');
document.addEventListener('mousemove', e => {
  cursor.style.left = e.clientX + 'px';
  cursor.style.top = e.clientY + 'px';
});
</script>

</body>
</html>
